# Copy to .env on the production server (never commit .env).

# Strong password for Postgres (must match DATABASE_URL below)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=nest-postgres-crud

# Comma-separated browser origins allowed to call the API with cookies
CORS_ORIGIN=https://your-frontend.vercel.app

# Where the app container binds on the host
# 127.0.0.1 = only localhost (use with Caddy proxy profile)
# 0.0.0.0 = expose directly on SERVER_IP:3000 (simplest first deploy)
APP_BIND=0.0.0.0
APP_PORT=3000

# Required only when starting with: docker compose --profile proxy up -d
# DOMAIN=api.yourdomain.com
