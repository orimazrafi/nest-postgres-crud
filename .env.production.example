# Copy to .env on the production server (never commit .env).

# Strong password for Postgres (must match DATABASE_URL below)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=nest-postgres-crud

# Comma-separated browser origins allowed to call the API with cookies.
# With the bundled web/nginx setup, use your public site origin (port 80, no :3000).
CORS_ORIGIN=http://YOUR_SERVER_IP

# Public web UI (nginx + React build)
WEB_BIND=0.0.0.0
WEB_PORT=80

# API is internal-only; nginx proxies /auth, /users, and /health to the app container.
APP_PORT=3000

# Set false when serving over plain HTTP (no TLS). Use true with HTTPS/Caddy.
COOKIE_SECURE=false

# Required only when starting with: docker compose --profile proxy up -d
# DOMAIN=api.yourdomain.com
